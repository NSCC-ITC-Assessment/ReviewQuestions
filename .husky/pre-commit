# Validate package.json is well-formed
node -e "JSON.parse(require('fs').readFileSync('package.json', 'utf8'))" || { echo 'package.json is not valid JSON'; exit 1; }

# Ensure no accidental hardcoded secrets in staged files.
# Matches patterns like: api_key = "abc123" or password = "hunter2"
# Ignores GitHub Actions expressions (${{ ... }}) and comment lines.
if git diff --cached --name-only | xargs grep -hE '(api_key|secret|password)\s*[=:]\s*"[^"$][^"]+"' 2>/dev/null | grep -v '^\s*#' | grep -qv '\${{'; then
  echo 'Possible hardcoded secret detected in staged files — review before committing.'
  exit 1
fi

# Run lint-staged (format and syntax-check staged files)
pnpm exec lint-staged
